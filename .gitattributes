# Normalise line endings to LF in the repository (checked out native on Windows).
* text=auto eol=lf

# Explicit text types
*.rs   text
*.toml text
*.md   text
*.html text
*.css  text
*.asm  text
*.ld   text
*.sh   text eol=lf
*.ps1  text eol=crlf

# Binary artifacts — never normalise
*.elf   binary
*.zip   binary
*.cpio  binary
*.o     binary
*.EFI   binary
BOOTX64.EFI binary
